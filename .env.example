# garmin-connect-mcp configuration
#
# NOTE: the server does NOT read this file (or any .env file) by itself.
# Provide these as real environment variables — e.g. via your shell,
# `docker compose --env-file`, the compose `env_file:` key, or a systemd
# `EnvironmentFile=`. Copy this file to `.env` for use with Docker Compose.
# `.env` is gitignored; never commit real credentials.

# --- Transport ---

# Transport mode: "stdio" (local Claude Code subprocess, default) or "http"
# (remote Streamable HTTP server behind a TLS-terminating reverse proxy).
# The --transport CLI flag takes precedence over this variable.
TRANSPORT_MODE=http

# Port the HTTP server listens on (HTTP mode only). The app always binds to
# 127.0.0.1; expose it publicly only through the reverse proxy.
# Default: 8080
PORT=8080

# --- Garmin Connect credentials ---

# REQUIRED in http mode. Optional in stdio mode, where the OS credential
# store (macOS Keychain / Windows Credential Manager / Linux libsecret) is
# used as a fallback when these are unset.
GARMIN_USERNAME=you@example.com
GARMIN_PASSWORD=your-garmin-password

# --- OAuth (http mode only) ---

# REQUIRED in http mode. Full public URL of the MCP endpoint as Claude will
# reach it through the reverse proxy. The path must be exactly /mcp; the
# OAuth resource identifier (RFC 9728) equals this value exactly.
GARMIN_MCP_PUBLIC_URL=https://garmin-mcp.example.com/mcp

# REQUIRED in http mode. bcrypt hash of the owner login password — the
# password itself never appears in config. Generate with:
#   npm run hash-password
# Quote the value: bcrypt hashes contain "$".
SERVER_OWNER_PASSWORD_HASH='$2b$12$replace-me-with-real-hash'

# SQLite file persisting OAuth clients, authorization codes, and tokens so
# they survive restarts. Point at a persistent path (e.g. a Docker volume).
# Default: ~/.garmin-mcp-auth.db
AUTH_DB_PATH=/var/lib/garmin-mcp/auth.db

# --- Storage ---

# Directory where Garmin OAuth tokens are cached so restarts don't trigger a
# fresh Garmin login. Point this at a persistent path (e.g. a Docker named
# volume mount).
# Default: ~/.garmin-mcp-tokens
TOKEN_CACHE_DIR=/var/lib/garmin-mcp/tokens

# --- Logging ---

# Minimum log level: debug, info, warn, or error. Logs are structured JSON
# on stderr (stdout is reserved for the MCP stdio transport).
# Default: info
LOG_LEVEL=info
