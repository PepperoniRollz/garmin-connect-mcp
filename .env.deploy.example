# Deployment .env template for docker-compose.yml — copy to .env next to the
# compose file on the server and chmod 600 (owner: the deploy user).
#
# Static container settings (TRANSPORT_MODE, PORT, TOKEN_CACHE_DIR,
# AUTH_DB_PATH) live in docker-compose.yml; this file holds the
# host-specific and secret values only.

# Garmin Connect account credentials (required).
GARMIN_USERNAME=you@example.com
GARMIN_PASSWORD=your-garmin-password

# Full public URL of the MCP endpoint behind the reverse proxy (required).
# Path must be exactly /mcp.
GARMIN_MCP_PUBLIC_URL=https://garmin-mcp.example.com/mcp

# bcrypt hash of the owner login password (required). Generate with:
#   npm run hash-password
# MUST be single-quoted: bcrypt hashes contain "$", and Docker Compose
# interpolates unquoted $ sequences in env files (single quotes disable
# interpolation; the quotes themselves are stripped).
SERVER_OWNER_PASSWORD_HASH='$2b$12$replace-me-with-real-hash'

# Host port the container publishes to on 127.0.0.1 (compose interpolation;
# the reverse proxy's upstream target). Default: 8081
GARMIN_MCP_HOST_PORT=8081

# Trusted reverse-proxy address as seen from inside the container. Default
# is the pinned bridge gateway from docker-compose.yml; override only if
# the hosting/network layout differs.
#TRUSTED_PROXY=172.28.0.1

# Minimum log level (debug, info, warn, error). Default: info
LOG_LEVEL=info
