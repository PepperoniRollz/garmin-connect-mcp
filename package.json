{
  "name": "garmin-connect-mcp",
  "version": "1.0.0",
  "description": "MCP server connecting Claude Code to Garmin Connect for fitness and health data",
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "hash-password": "tsx scripts/hash-password.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p scripts/tsconfig.json",
    "lint": "gts lint",
    "fix": "gts fix",
    "test": "tsx scripts/run-e2e.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "garmin-connect": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "gts": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
